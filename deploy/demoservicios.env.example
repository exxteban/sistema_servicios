# Preset para demoservicios.pysystems.online
# Copiar en el servidor como deploy/demoservicios.env o exportar las variables al ejecutar.
# No commitear este archivo con claves reales si lo copias como demoservicios.env.

DOMAIN=demoservicios.pysystems.online
EXPECTED_PUBLIC_IP=38.247.128.125
SERVICE_NAME=sistema-demoservicios
APP_PORT=3117
ENV_FILE_PATH=/etc/sistema_demoservicios.env

DB_NAME=demoservicios
DB_USER=demoservicios_user
DB_HOST=localhost
DB_PORT=3306

# Obligatorio para crear/actualizar la BD y usuario MariaDB.
DB_ROOT_PASSWORD=cambiar-root-mariadb

# Opcional. Si quedan vacios, install.sh genera claves seguras y las imprime una sola vez.
DB_PASSWORD=
SECRET_KEY=
APP_BOOTSTRAP_ADMIN_PASSWORD=
APP_BOOTSTRAP_ROOT_USERNAME=root
APP_BOOTSTRAP_ROOT_PASSWORD=

SERVICE_USER=administrator
SERVICE_GROUP=administrator
BACKUP_DIR=/home/administrator/backups/demoservicios

APP_CONFIG=production
APP_SERVER=waitress
HOST=127.0.0.1
SETUP_CADDY=1
SERVER_TIMEZONE=America/Asuncion

# Demo sin integraciones externas por defecto.
WHATSAPP_ENABLED=0
WHATSAPP_DRY_RUN=1
AI_ENABLED=0

# Actualizacion posterior al install.
RUN_TIENDA_BUILD=1
RUN_TIENDA_MIGRATIONS=1
RUN_APP_BOOTSTRAP_MIGRATIONS=1
RUN_TIENDA_UPLOAD_PERMISSIONS=1
