# Preset para lionsburguer.pysystems.online
# Copiar en el servidor como deploy/lionsburguer.env o exportar las variables al ejecutar.
# No commitear este archivo con claves reales si lo copias como lionsburguer.env.

DOMAIN=lionsburguer.pysystems.online
EXPECTED_PUBLIC_IP=173.208.162.124
SERVICE_NAME=sistema-lionsburguer
APP_PORT=3117
ENV_FILE_PATH=/etc/sistema_lionsburguer.env

DB_NAME=lionsburguer
DB_USER=lionsburguer_user
DB_HOST=localhost
DB_PORT=3306

# Si MariaDB root usa password, definelo aqui.
# Si el servidor usa auth_socket y ejecutas el deploy con sudo/root, puede quedar vacio.
DB_ROOT_PASSWORD=

# Opcional. Si quedan vacios, install.sh genera claves seguras y las imprime una sola vez.
DB_PASSWORD=
SECRET_KEY=
APP_BOOTSTRAP_ADMIN_PASSWORD=
APP_BOOTSTRAP_ROOT_USERNAME=root
APP_BOOTSTRAP_ROOT_PASSWORD=

SERVICE_USER=administrator
SERVICE_GROUP=administrator
BACKUP_DIR=/home/administrator/backups/lionsburguer

APP_CONFIG=production
APP_SERVER=waitress
HOST=127.0.0.1
SETUP_CADDY=1
SERVER_TIMEZONE=America/Asuncion

# Integraciones externas apagadas por defecto para el primer deploy.
WHATSAPP_ENABLED=0
WHATSAPP_DRY_RUN=1
AI_ENABLED=0

# Actualizacion posterior al install.
RUN_TIENDA_BUILD=1
RUN_TIENDA_MIGRATIONS=1
RUN_GASTRONOMIA_MIGRATIONS=1
RUN_APP_BOOTSTRAP_MIGRATIONS=1
RUN_TIENDA_UPLOAD_PERMISSIONS=1
