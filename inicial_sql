-- Trigger para actualizar fecha_modificacion en productos
CREATE TRIGGER tr_productos_fecha_modificacion
AFTER UPDATE ON productos
FOR EACH ROW
BEGIN
    UPDATE productos SET fecha_modificacion = CURRENT_TIMESTAMP WHERE id_producto = NEW.id_producto;
END;

-- Trigger para evitar eliminar el cliente Consumidor Final (ID=1)
CREATE TRIGGER tr_proteger_consumidor_final
BEFORE DELETE ON clientes
FOR EACH ROW
WHEN OLD.id_cliente = 1
BEGIN
    SELECT RAISE(ABORT, 'No se puede eliminar el cliente Consumidor Final');
END;

-- Trigger para evitar eliminar la Caja Principal (ID=1)
CREATE TRIGGER tr_proteger_caja_principal
BEFORE DELETE ON cajas
FOR EACH ROW
WHEN OLD.id_caja = 1
BEGIN
    SELECT RAISE(ABORT, 'No se puede eliminar la Caja Principal');
END;

