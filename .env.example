# Configuración del Sistema - Ejemplo
# Copia este archivo a .env y ajusta los valores según tu entorno

# Configuración de Flask
SECRET_KEY=clave-secreta-cambiar-en-produccion-123456
FLASK_ENV=development
FLASK_APP=run.py

# Configuración de Base de Datos
# Para SQLite (por defecto, comentar DATABASE_URL):
# DATABASE_URL=sqlite:///inventario.db

# Para MySQL/MariaDB (descomentar y configurar):
DATABASE_URL=mysql+pymysql://silvio_user:tu_password_aqui@localhost:3306/bd_silvio?charset=utf8mb4

# Configuración de la Aplicación
APP_TIMEZONE=America/Asuncion

# Configuración de Cookies (Producción)
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SECURE=false
REMEMBER_COOKIE_SAMESITE=Lax

# CRM WhatsApp (default: habilitado)
CRM_ENABLED=1

# WhatsApp Cloud API (ejemplo - NO pegar tokens reales aquí)
WHATSAPP_ENABLED=1
WHATSAPP_PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID
WHATSAPP_ACCESS_TOKEN=TU_WHATSAPP_ACCESS_TOKEN
WHATSAPP_WEBHOOK_VERIFY_TOKEN=mi_token_webhook_2026_xxx
WHATSAPP_DRY_RUN=0

# IA (ejemplo - NO pegar API keys reales aquí)
AI_ENABLED=1
AI_PROVIDER=openai
AI_MODEL=gpt-5-mini
AI_API_KEY=TU_OPENAI_API_KEY
AI_REASONING_EFFORT=medium
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.7

# Limites WhatsApp
WHATSAPP_RATE_LIMIT_PER_PHONE=20
WHATSAPP_RATE_LIMIT_GLOBAL=500
WHATSAPP_CODIGO_EXPIRACION_DIAS=30
WHATSAPP_SESION_HORAS=24
WHATSAPP_MAX_INTENTOS_CODIGO=3

# Asesores WhatsApp
WHATSAPP_ASESOR_TIMEOUT_SEGUNDOS=180
WHATSAPP_ASESOR_HEARTBEAT_SEGUNDOS=30
WHATSAPP_ASESOR_MAX_CONVERSACIONES=5
WHATSAPP_TIMEOUT_SCHEDULER=1
WHATSAPP_TIMEOUT_INTERVAL_SECONDS=30
CRM_BANDEJA_JEFE_MIN_NIVEL=100

# Notificaciones automaticas WhatsApp
WHATSAPP_NOTIFICAR_LISTO=1
WHATSAPP_NOTIFICAR_ESPERA_CLIENTE=1
WHATSAPP_NOTIFICAR_NO_SE_PUDO=0

# DeepSeek (para switchear, setear AI_PROVIDER=deepseek)
AI_ENABLED=1
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=TU_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# Logging
LOG_LEVEL=INFO
LOG_REQUEST_ACCESS=0
LOG_REQUEST_VERBOSE=0
LOG_REQUEST_BODY=0
LOG_REQUEST_BODY_MAX_CHARS=600
LOG_REQUEST_VERBOSE_IGNORE_PATHS=/api/dashboard/totales,/api/dashboard,/api/notificaciones,/whatsapp/webhook
LOG_RESPONSE_ERROR_BODY=0
LOG_RESPONSE_ERROR_BODY_MAX_CHARS=400
LOG_WHATSAPP_WEBHOOK=0
LOG_DB_COMMITS=0
OBS_REQUEST_SLOW_MS=800
OBS_SLOW_QUERY_MS=250
OBS_SQL_TEXT_MAX_LEN=240
OBS_CRITICAL_ENDPOINTS=/dashboard,/api/tienda,/tienda,/whatsapp,/agenda

DOMAIN=app.tudominio.com
SETUP_CADDY=1
SERVICE_NAME=sistema-telefonica
SERVER_TIMEZONE=America/Asuncion
