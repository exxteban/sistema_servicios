dist/
build/

# Flask
instance/
.webassets-cache

# Base de datos
*.db
*.db-journal
*.sqlite
*.sqlite3

# Dumps y backups SQL (pueden contener datos reales del cliente)
*_backup*.sql
bd_*_*.sql
dump_*.sql
*.dump.sql
# Nota: scripts de migracion legitimos (migrations/*.sql, setup_local_db.sql) siguen versionados

# Datos locales del cliente (no versionar)
Base de datos/*
!Base de datos/*.csv.bundle

# Archivos de salida/diagnostico temporales
_tmp_*
*_output.txt
ticket_config_output.txt
verify_output*.txt

# CSV de importación (se copia al servidor, no se versiona)
deploy/**/*.csv

# Variables de entorno
.env
.env.local
.env.*.local
deploy/*.env

# Logs
logs/
*.log

# Artefactos locales varios
.local-arm/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Backups
*.bak
*.backup
backups/

# Archivos subidos por los usuarios
app/static/uploads/
app/static/tienda_uploads/

# Node modules (para Tailwind)
node_modules/
